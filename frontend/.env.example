# Copy to .env (gitignored). Vite exposes VITE_* vars to the client bundle.

# Orchestrator endpoint
# For laptop A use: http://localhost:8000
# For laptop B use: http://<laptopA-LAN-IP>:8000  (find with: ipconfig getifaddr en0)
VITE_ORCH_URL=http://localhost:8000

# Firebase web app config (Project settings > General > Your apps > Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
