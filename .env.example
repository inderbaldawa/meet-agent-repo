# Copy to .env and fill in real values. .env is gitignored.

# Google Cloud
GCP_PROJECT_ID=meet-agents-CHANGEME
GOOGLE_APPLICATION_CREDENTIALS=/Users/budha.mandapaka/keys/meet-agents-sa.json

# Gemini (use a key from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Serper (full Google Search proxy — sign up at https://serper.dev)
SERPER_API_KEY=

# Orchestrator binding
ORCH_HOST=0.0.0.0
ORCH_PORT=8000

# CORS: comma-separated list of allowed origins for the React frontend
# Include localhost for laptop A's own use, and laptop A's LAN IP origin for laptop B
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
